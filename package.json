{
  "name": "game-polish-lab",
  "displayName": "Game Polish Lab",
  "description": "Phaser-first polish workflow tools for pixel-art game feel, VFX readability, and UI/HUD polish.",
  "version": "0.6.4",
  "publisher": "local-dev",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:gamePolishLab.initializeProfile",
    "onCommand:gamePolishLab.runPhaserPixelAudit",
    "onCommand:gamePolishLab.createPolishTask",
    "onCommand:gamePolishLab.createFinishStagePolishPlan",
    "onCommand:gamePolishLab.createRescueTask",
    "onCommand:gamePolishLab.createPixelPolishKit",
    "onCommand:gamePolishLab.listPixelPolishKits",
    "onCommand:gamePolishLab.generateKitImplementationPrompt",
    "onCommand:gamePolishLab.createStyleGuide",
    "onCommand:gamePolishLab.generateCodexPrompt",
    "onCommand:gamePolishLab.createTrialReport",
    "onCommand:gamePolishLab.updateTrialResult",
    "onCommand:gamePolishLab.openTrialReports",
    "onCommand:gamePolishLab.checkCodexScope",
    "onCommand:gamePolishLab.setPerformanceMode",
    "onCommand:gamePolishLab.clearCache",
    "onCommand:gamePolishLab.showPerformanceDiagnostics",
    "onCommand:gamePolishLab.createVisualDiagnosisTask",
    "onCommand:gamePolishLab.createTuningExperiment",
    "onCommand:gamePolishLab.createRollbackPrompt",
    "onCommand:gamePolishLab.openAssetContactSheet",
    "onCommand:gamePolishLab.openVisualTuningDashboard",
    "onCommand:gamePolishLab.tuneVisualSurface",
    "onCommand:gamePolishLab.refreshAssetContracts",
    "onCommand:gamePolishLab.addFieldNote",
    "onCommand:gamePolishLab.markLatestTuningResult"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gamePolishLab.initializeProfile",
        "title": "Game Polish Lab: Initialize Project Profile"
      },
      {
        "command": "gamePolishLab.runPhaserPixelAudit",
        "title": "Game Polish Lab: Run Phaser Pixel Audit"
      },
      {
        "command": "gamePolishLab.createPolishTask",
        "title": "Game Polish Lab: Create Polish Task"
      },
      {
        "command": "gamePolishLab.createFinishStagePolishPlan",
        "title": "Game Polish Lab: Create Finish-Stage Polish Plan"
      },
      {
        "command": "gamePolishLab.createRescueTask",
        "title": "Game Polish Lab: Create Rescue Task"
      },
      {
        "command": "gamePolishLab.createPixelPolishKit",
        "title": "Game Polish Lab: Create Pixel Polish Kit"
      },
      {
        "command": "gamePolishLab.listPixelPolishKits",
        "title": "Game Polish Lab: List Pixel Polish Kits"
      },
      {
        "command": "gamePolishLab.generateKitImplementationPrompt",
        "title": "Game Polish Lab: Generate Kit Implementation Prompt"
      },
      {
        "command": "gamePolishLab.createStyleGuide",
        "title": "Game Polish Lab: Create Pixel Art Style Guide"
      },
      {
        "command": "gamePolishLab.generateCodexPrompt",
        "title": "Game Polish Lab: Generate Codex Prompt"
      },
      {
        "command": "gamePolishLab.createTrialReport",
        "title": "Game Polish Lab: Create Real Project Trial Report"
      },
      {
        "command": "gamePolishLab.updateTrialResult",
        "title": "Game Polish Lab: Update Trial Result"
      },
      {
        "command": "gamePolishLab.openTrialReports",
        "title": "Game Polish Lab: Open Trial Reports"
      },
      {
        "command": "gamePolishLab.checkCodexScope",
        "title": "Game Polish Lab: Check Codex Scope"
      },
      {
        "command": "gamePolishLab.setPerformanceMode",
        "title": "Game Polish Lab: Set Performance Mode"
      },
      {
        "command": "gamePolishLab.clearCache",
        "title": "Game Polish Lab: Clear Scan Cache"
      },
      {
        "command": "gamePolishLab.showPerformanceDiagnostics",
        "title": "Game Polish Lab: Show Performance Diagnostics"
      },
      {
        "command": "gamePolishLab.createVisualDiagnosisTask",
        "title": "Game Polish Lab: Create Visual Diagnosis Task"
      },
      {
        "command": "gamePolishLab.createTuningExperiment",
        "title": "Game Polish Lab: Create Tuning Experiment"
      },
      {
        "command": "gamePolishLab.createRollbackPrompt",
        "title": "Game Polish Lab: Create Rollback Prompt"
      },
      {
        "command": "gamePolishLab.openAssetContactSheet",
        "title": "Game Polish Lab: Open Asset Contact Sheet"
      },
      {
        "command": "gamePolishLab.openVisualTuningDashboard",
        "title": "Game Polish Lab: Open Visual Tuning Dashboard"
      },
      {
        "command": "gamePolishLab.tuneVisualSurface",
        "title": "Game Polish Lab: Tune Visual Surface"
      },
      {
        "command": "gamePolishLab.refreshAssetContracts",
        "title": "Game Polish Lab: Refresh Asset Contracts"
      },
      {
        "command": "gamePolishLab.addFieldNote",
        "title": "Game Polish Lab: Add Field Note"
      },
      {
        "command": "gamePolishLab.markLatestTuningResult",
        "title": "Game Polish Lab: Mark Latest Tuning Result"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "tsc --noEmit -p ./",
    "test": "npm run compile && node dist/test/monsterFarmDeepAudit.spec.js"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.5.3"
  }
}
